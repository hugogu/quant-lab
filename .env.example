# DB
POSTGRES_DB=quantlab
POSTGRES_USER=quant
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_PORT=8000
API_TOKEN=local-dev-token

# Web (streamlit)
STREAMLIT_PORT=8501
API_BASE_URL=http://api:8000

# Data sources (Phase 2.0: optional; akshare works without keys)
TUSHARE_TOKEN=

# Source chain: comma-separated source names in priority order (lowest number wins).
# Sources missing from this list keep their DB priority; this overrides per-request.
SOURCE_ASTOCK_CHAIN=akshare_astock,baostock_astock,tushare_astock
SOURCE_FUND_CHAIN=akshare_fund

# Failover behavior
SOURCE_FAILOVER_ENABLED=true
SOURCE_LOOKBACK_BUFFER_DAYS=7   # re-fetch last N days on each run (handles restated values)

# Hard timeouts (Phase 2.4: subprocess-isolated fetchers)
# Per-source: SIGKILL the fetch subprocess after this many seconds. Bounds CPU
# when an upstream library misbehaves (e.g. baostock busy-looping on a dead
# socket under GFW). Per-source defaults also live in data_source.config and
# override this if set.
SOURCE_REQUEST_TIMEOUT_DEFAULT=60
# Per-symbol: wall-clock cap for the full failover chain on one symbol.
# Independent of per-source: bounds the whole "akshare → tushare → baostock"
# sequence so one stuck symbol can't block the batch.
PER_SYMBOL_TIMEOUT_SECONDS=180

# Scheduler (worker)
COLLECT_CRON_ASTOCK=0 17 * * 1-5    # 17:00 every weekday (after market close)
COLLECT_CRON_FUND=0 22 * * *       # 22:00 every day
FACTOR_CRON=30 17 * * 1-5           # 17:30 every weekday (after OHLCV in)
FACTOR_LOOKBACK_DAYS=252
SIGNAL_CRON=45 17 * * 1-5           # 17:45 every weekday (after factors in)
